{
  "name": "cc65-intel-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "cc65-dialect C intelligence: a parser+resolver engine and LSP for the cc65 6502 C toolchain.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "pre-commit install >/dev/null 2>&1 || true",
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc -p tsconfig.eslint.json --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "madge:circular": "madge --circular --extensions ts packages/*/src"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "madge": "^8.0.0",
    "prettier": "^3.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.8"
  }
}
