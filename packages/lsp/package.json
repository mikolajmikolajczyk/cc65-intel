{
  "name": "@cc65-intel/lsp",
  "version": "0.5.0",
  "description": "Thin LSP server over @cc65-intel/core — cc65 C completion, hover, diagnostics. Browser (worker) + node (stdio).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikolajmikolajczyk/cc65-intel.git",
    "directory": "packages/lsp"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cc65-lsp": "./dist/node.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "tsc -b"
  },
  "dependencies": {
    "@cc65-intel/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vscode-jsonrpc": "^8.2.0"
  }
}
