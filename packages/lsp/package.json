{
  "name": "@cc65-intel/lsp",
  "version": "0.0.0",
  "description": "Thin LSP server over @cc65-intel/core — cc65 C completion, hover, diagnostics. Browser (worker) + node (stdio).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@cc65-intel/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "vscode-jsonrpc": "^8.2.0"
  }
}
